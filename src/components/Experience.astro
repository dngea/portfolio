---
// TODO: add resaltado con underline quizas
const abss = {
  roleSummary:
    "Focus on building and maintaining web applications using Next.js in collaboration with backend and design teams.",

  highlights: [
    "Developed a drag-and-drop media library, integrated into a custom CMS for non-technical client use, integrated using intertia/react.",
    "Built a reusable React component library, packaged as a private npm module and consumed across multiple client projects.",
    "Designed headless frontend architecture on top of a Laravel backend, keeping the two decoupled.",
    "Implemented multi-language support (next-intl) with URL-driven filters and pagination that stay in sync across locales.",
    "Worked with authentication flows and REST API integrations for production apps.",
    "Added testing using Vitest for core utility, avoiding breaking features on refactors.",
    "Designed components and flows with an accessibility-first approach (semantics, contrasts, navigation, ARIA tags).",
  ],
};
---

<section class="mx-auto max-w-5xl space-y-8">
  <h2 class="text-light text-3xl font-bold">Experience</h2>
  <div class="row">
    <div class="col-6">
      <div class="card mt-5">
        <div class="card-body group space-y-4 px-5">
          <section class="vert-hr group space-y-4 px-1">
            <div
              class="bg-light group-hover:bg-cream absolute top-3.5 -left-[12px] z-1 size-[10px] -translate-1/2 rounded-full transition group-hover:scale-130"
            >
            </div>

            <h5
              class="text-dark bg-cream mb-1 w-fit px-2 font-medium hover:contrast-110"
            >
              <a href="https://www.abss.at/" target="_blank">
                abss interactive
              </a>
            </h5>

            <h6 class="font-weight-bolder text-light">
              Frontend Developer
              <span class="text-light"
                >&nbsp;|&nbsp;April 2025 &ndash; Present
              </span>
            </h6>

            <div class="space-y-2">
              <p class="text-light">
                {abss.roleSummary}
              </p>

              <ul
                class="marker:text-light/80 text-light/95 list-disc space-y-1.5 pl-5"
              >
                {
                  abss.highlights.map((line) => (
                    <li class="text-[15px] leading-relaxed">{line}</li>
                  ))
                }
              </ul>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .vert-hr {
    position: relative;

    &:after {
      content: "";
      position: absolute;
      z-index: 0;
      top: 1px;
      bottom: 6px;
      left: -12.5px;
      border-left: 1px solid var(--color-light);
      transform: translate(-50%);
    }
  }
  .title-dot {
    margin-left: -27px;
    font-size: 12px;
    z-index: 99;
    color: var(--color-light);
    vertical-align: middle;

    &:last-child {
      font-size: 0.4em;
    }

    &-sm {
      left: 4px;
      margin-left: -27px;
      font-size: 10px;
      z-index: 99;
      color: var(--color-light);
      vertical-align: middle;

      &:last-child {
        font-size: 0.5em;
      }
    }
  }
  .title {
    margin-left: -22px;
    color: var(--color-light);
  }
</style>
