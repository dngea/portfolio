---
// TODO: add resaltado con underline quizas
const abss = {
  roleSummary:
    "Focus on building and maintaining real-world web applications in collaboration with backend and design teams.",

  highlights: [
    "Integrated REST APIs and authentication flows into production applications.",
    "Built headless frontend architectures connected to backend-driven systems.",
    "Implemented multi-language (i18n) websites with consistent UX across locales.",
    "Developed a reusable media library integrated into a custom CMS for client use.",
    "Created and maintained static and dynamic pages based on product requirements.",
    "Improved accessibility (a11y) and performance across key user-facing features.",
    "Added automated tests to increase reliability and reduce regressions.",
    "Work on npm packages to be reused across projects. Handling style and logic to make it flexible.",
  ],
};
---

<section class="mx-auto max-w-5xl space-y-8">
  <h2 class="text-light text-3xl font-bold">Experience</h2>
  <div class="row">
    <div class="col-6">
      <div class="card mt-5">
        <div class="card-body group space-y-4 px-5">
          <section class="vert-hr group space-y-4 px-1">
            <div
              class="bg-light absolute top-3.5 -left-3.25 size-2 -translate-1/2 rounded-full transition group-hover:scale-125"
            >
            </div>

            <h5
              class="text-dark bg-cream mb-1 w-fit px-2 font-medium hover:contrast-110"
            >
              <a href="https://www.abss.at/" target="_blank">
                abss interactive
              </a>
            </h5>

            <h6 class="font-weight-bolder text-light">
              Frontend Developer
              <span class="text-light"
                >&nbsp;|&nbsp;April 2025 &ndash; Present
              </span>
            </h6>

            <div class="space-y-2">
              <p class="text-light">
                {abss.roleSummary}
              </p>

              <ul
                class="marker:text-light/80 text-light/95 list-disc space-y-1.5 pl-5"
              >
                {
                  abss.highlights.map((line) => (
                    <li class="text-[15px] leading-relaxed">{line}</li>
                  ))
                }
              </ul>
            </div>
          </section>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .vert-hr {
    position: relative;

    &:after {
      content: "";
      position: absolute;
      z-index: 0;
      top: 14px;
      bottom: 6px;
      left: -13.1px;
      border-left: 1px solid var(--color-light);
      transform: translate(-50%);
    }
  }
  .title-dot {
    margin-left: -27px;
    font-size: 12px;
    z-index: 99;
    color: var(--color-light);
    vertical-align: middle;

    &:last-child {
      font-size: 0.4em;
    }

    &-sm {
      left: 4px;
      margin-left: -27px;
      font-size: 10px;
      z-index: 99;
      color: var(--color-light);
      vertical-align: middle;

      &:last-child {
        font-size: 0.5em;
      }
    }
  }
  .title {
    margin-left: -22px;
    color: var(--color-light);
  }
</style>
