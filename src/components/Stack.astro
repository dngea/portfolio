---
const stack = [
  "TypeScript",
  "React",
  "Next.js",
  "Tailwind CSS",
  "HTML",
  "CSS",
  "REST/GraphQL",
  "Astro",
  "Vitest",
  "Sass",
  "Storybook",
  "Alpine.js",
  "Figma",
];
---

<!-- todo: scroll top -margin -->
<section class="mx-auto max-w-5xl scroll-mt-50 space-y-8" id="stack">
  <h2 class="text-light text-3xl font-bold">Stack</h2>
  <ul
    class="grid h-full w-full grid-flow-col grid-rows-7 gap-x-8 gap-y-2 sm:grid-rows-4 sm:gap-2"
  >
    {stack.map((i) => <li class="text-light w-fit whitespace-nowrap">{i}</li>)}
  </ul>
</section>
