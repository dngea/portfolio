---
import clsx from "clsx";

const { className } = Astro.props;
---

<div
  class={clsx(
    "bg-light main-layout relative  text-dark min-h-screen p-4",
    className,
  )}
>
  <div
    id="dark-overlay"
    class="bg-dark pointer-events-none absolute inset-0 z-0 opacity-0 transition-opacity duration-200 ease-linear"
  >
  </div>

  <slot name="background" />

  <div
    class="relative z-1 mx-auto mt-22 mb-16 max-w-5xl space-y-12 sm:mt-32 sm:mb-30 sm:space-y-18 md:mt-40 lg:mt-50"
  >
    <slot />
  </div>
</div>
