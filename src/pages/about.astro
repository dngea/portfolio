---
import MainLayout from "@/layouts/MainLayout.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import FeatureExample from "@/components/Feature";
import { Inbox } from "lucide-react";
import Linkedin from "@/svg/Linkedin.astro";
import Form from "@/components/Form";
import Email from "@/components/atoms/Email";

const presentation =
  "Originally from Granada, in southern Spain,  where I began my studies in Information Science.  After my bachelor's, I moved to Portugal to pursue a  master's in Human Computer Interaction (HCI) in the beautiful and rainy city of  Porto, where I spent two years. Having completed my  studies, I moved to Vienna, Austria, to kickstart my  career as a Front-end developer.";

const languages = ["English", "German", "Spanish", "Portuguese"];

const STUDIES = [
  {
    dates: "2022 - 2024",
    study: `<a href="https://fe.up.pt/estudar/mm/?lang=en" target="_blank" class="hover:underline">[Master’s Degree] <strong>Human Computer Interaction</strong> · Faculty of Engineering at University of Porto, Portugal</a>`,
    highlights: [
      "UX/UI design",
      "Frontend development",
      "Interactive installations",
      "Creative coding",
      "Game development",
    ],
    link: "https://fe.up.pt/estudar/mm/?lang=en",
  },
  {
    dates: "2018 - 2022",
    study: `<a href="https://www.ugr.es/en/study/undergraduate/bachelors-degree-information-sciences" target="_blank" class="hover:underline">[Bachellor’s Degree] <strong>Information Sciences (Web Specialization)</strong> · University of Granada, Spain</a>`,
    highlights: [
      "Databases",
      "CMS",
      "Information architecture",
      "Web architecture",
    ],
    link: "https://www.ugr.es/en/study/undergraduate/bachelors-degree-information-sciences",
  },
];
---

<Layout title="About">
  <MainLayout>
    <!-- Dot grid texture -->
    <div
      slot="background"
      class="pointer-events-none fixed inset-0"
      style="background-image: radial-gradient(circle, rgba(0,0,0,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>

    <section class="grid grid-cols-1 items-center gap-8 sm:grid-cols-2">
      <figure
        class="max-w-[350px] justify-self-center overflow-hidden rounded-sm shadow-xl"
      >
        <Image
          src={"/images/about/profile.webp"}
          alt="Profile picture of Daniel"
          width={350}
          height={500}
          sizes="350px"
          class="h-auto w-full rounded-sm object-cover"
        />
      </figure>

      <div class="flex flex-col justify-center gap-6">
        <header class="space-y-px">
          <p class="text-base opacity-70">Hola</p>
          <h1 class="text-3xl font-semibold">I&apos;m Daniel</h1>
        </header>

        <div class="flex items-center gap-2 text-sm">
          <span class="opacity-70">Location</span>
          <Badge variant={"default"} className="bg-clay text-light">
            Vienna, Austria
          </Badge>
        </div>

        <p class="leading-relaxed">
          {presentation}
        </p>

        <div class="flex flex-wrap items-center gap-2">
          {
            languages.map((lang) => (
              <Badge className="capitalize" key={lang}>
                {lang}
              </Badge>
            ))
          }
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <h2 class="text-3xl font-bold">Studies</h2>

      <div class="relative space-y-10 pl-8">
        <!-- línea vertical conectora -->
        <div class="bg-clay/20 absolute top-[20px] bottom-1.5 left-[5px] w-px">
        </div>

        {
          STUDIES.map((study) => (
            <div class="group relative">
              <span class="bg-clay border-light absolute top-1 -left-[32px] size-3 rounded-full border-2 transition-transform group-hover:scale-135 group-hover:contrast-125" />

              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <span class="w-30 shrink-0 text-sm tracking-wide opacity-60 group-hover:opacity-80">
                  {study.dates}
                </span>

                <div class="space-y-1">
                  <p class="leading-snug font-medium" set:html={study.study} />
                  <p class="text-sm italic opacity-70">
                    {study.highlights.join(" · ")}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="flex justify-end px-4 pt-2">
        <a
          href="/downloads/daniel_gea_resume.pdf"
          download="Daniel_Gea_Resume"
          class={buttonVariants()}
        >
          Download Resume
        </a>
      </div>
    </section>

    <section>
      <FeatureExample client:visible />
    </section>

    <section class="grid w-full gap-8 md:grid-cols-2" id="contact">
      <div
        class="mx-auto flex w-full flex-col justify-center gap-8 p-8 lg:w-[80%]"
      >
        <h2 class="text-3xl font-bold">Get in touch</h2>

        <div class="divide-y divide-gray-300">
          <div class="flex items-center gap-3 py-4">
            <div class="flex w-8 justify-center">
              <Inbox className="size-7" />
            </div>
            <Email email="dngeap@gmail.com" client:idle />
          </div>

          <div class="flex items-center gap-3 py-4">
            <div class="flex w-8 justify-center">
              <Linkedin class="size-8" />
            </div>
            <a
              href="https://www.linkedin.com/in/dngea/"
              class="hover:underline"
              target="_blank"
            >
              Daniel Gea Palenzuela
            </a>
          </div>
        </div>
      </div>

      <div>
        <Form client:load />
      </div>
    </section>
  </MainLayout>
</Layout>
