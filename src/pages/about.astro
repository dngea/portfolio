---
import MainLayout from "@/layouts/MainLayout.astro";
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import { Badge } from "@/components/ui/badge";
import { buttonVariants } from "@/components/ui/button";
import FeatureExample from "@/components/Feature";
import { Inbox } from "lucide-react";
import Linkedin from "@/svg/Linkedin.astro";
import Form from "@/components/Form";
import Email from "@/components/atoms/Email";
import { PRESENTATION, LANGUAGES, ABSS, STUDIES } from "@/data/index";
---

<Layout title="About">
  <MainLayout>
    <!-- Dot grid texture -->
    <div
      slot="background"
      class="pointer-events-none fixed inset-0"
      style="background-image: radial-gradient(circle, rgba(0,0,0,0.08) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>

    <section class="grid grid-cols-1 items-center gap-8 sm:grid-cols-2">
      <figure
        class="max-w-48 justify-self-center overflow-hidden rounded-sm shadow-xl md:max-w-[350px]"
      >
        <Image
          src={"/images/about/profile.webp"}
          alt="Profile picture of Daniel"
          width={350}
          height={500}
          sizes="350px"
          class="h-auto w-full rounded-sm object-cover"
        />
      </figure>

      <div class="flex flex-col justify-center gap-6">
        <header class="space-y-px">
          <p class="text-base opacity-70">Hola</p>
          <h1 class="text-3xl font-semibold">I&apos;m Daniel</h1>
        </header>

        <div class="flex items-center gap-2 text-sm">
          <span class="opacity-70">Location</span>
          <Badge variant={"default"} className="bg-clay text-light">
            Vienna, Austria
          </Badge>
        </div>

        <p class="leading-relaxed">{PRESENTATION}</p>

        <div class="flex flex-wrap items-center gap-2">
          {
            LANGUAGES.map((lang) => (
              <Badge className="capitalize" key={lang}>
                {lang}
              </Badge>
            ))
          }
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <h2 class="text-3xl font-bold">Experience</h2>
      <div class="row">
        <div class="col-6">
          <div class="card mt-5">
            <div class="card-body group relative space-y-4 px-5">
              <section class="group space-y-4 px-1">
                <div
                  class="bg-dark absolute top-0 -bottom-4 left-[5px] w-[1px]"
                >
                </div>

                <div
                  class="bg-clay absolute top-3.5 left-[6px] z-1 size-[10px] -translate-1/2 rounded-full transition group-hover:scale-130"
                >
                </div>

                <h5
                  class="text-dark bg-cream mb-1 w-fit px-2 font-medium hover:contrast-110"
                >
                  <a href="https://www.abss.at/" target="_blank">
                    abss interactive
                  </a>
                </h5>

                <h6 class="font-weight-bolder text-dark">
                  Frontend Developer
                  <span class="text-dark"
                    >&nbsp;|&nbsp;April 2025 &ndash; Present
                  </span>
                </h6>

                <div class="space-y-2">
                  <p class="text-dark">
                    {ABSS.roleSummary}
                  </p>

                  <ul
                    class="marker:text-dark/80 text-dark/95 list-disc space-y-1.5 pl-5"
                  >
                    {
                      ABSS.highlights.map((line) => (
                        <li class="text-[15px] leading-relaxed">{line}</li>
                      ))
                    }
                  </ul>
                </div>
              </section>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="space-y-8">
      <h2 class="text-3xl font-bold">Studies</h2>

      <div class="relative space-y-10 pl-8">
        <!-- línea vertical conectora -->
        <div class="bg-dark absolute top-[0px] -bottom-10 left-[5px] w-[1px]">
        </div>

        {
          STUDIES.map((study) => (
            <div class="group relative">
              <span class="bg-clay absolute top-1 -left-[31px] size-[10px] rounded-full transition-transform group-hover:scale-135 group-hover:contrast-125" />

              <div class="flex flex-col gap-1 sm:flex-row sm:gap-4">
                <span class="w-30 shrink-0 text-sm tracking-wide opacity-60 group-hover:opacity-80">
                  {study.dates}
                </span>

                <div class="space-y-1">
                  <p class="leading-snug font-medium" set:html={study.study} />
                  <p class="text-sm italic opacity-70">
                    {study.highlights.join(" · ")}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="flex justify-end px-4 pt-2">
        <a
          href="/downloads/daniel_gea_resume.pdf"
          download="Daniel_Gea_Resume"
          class={buttonVariants()}
        >
          Download Resume
        </a>
      </div>
    </section>

    <section>
      <FeatureExample client:visible />
    </section>

    <section class="grid w-full gap-8 md:grid-cols-2" id="contact">
      <div
        class="mx-auto flex w-full flex-col justify-center gap-8 sm:p-4 md:p-8 lg:w-[80%]"
      >
        <h2 class="text-3xl font-bold">Get in touch</h2>

        <div class="divide-y divide-gray-300 max-sm:px-8">
          <div class="flex items-center gap-3 py-4">
            <div class="flex w-8 justify-center">
              <Inbox className="size-7" />
            </div>
            <Email email="dngeap@gmail.com" client:idle />
          </div>

          <div class="flex items-center gap-3 py-4">
            <div class="flex w-8 justify-center">
              <Linkedin class="size-8" />
            </div>
            <a
              href="https://www.linkedin.com/in/dngea/"
              class="hover:underline"
              target="_blank"
            >
              Daniel Gea Palenzuela
            </a>
          </div>
        </div>
      </div>

      <div>
        <Form client:load />
      </div>
    </section>
  </MainLayout>
</Layout>
