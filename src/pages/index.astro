---
import Layout from "../layouts/Layout.astro";
import Welcome from "../components/Welcome.astro";
import Skills from "../components/Skills.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/ProjectsSection.astro";
import Publications from "@/components/PublicationsSection.astro";
import Cta from "@/components/Cta.astro";
---

<Layout>
  <div class="bg-light relative">
    <!-- Dot grid texture -->
    <div
      class="pointer-events-none fixed inset-0"
      style="background-image: radial-gradient(circle, rgba(0,0,0,0.15) 1px, transparent 1px); background-size: 28px 28px;"
    >
    </div>

    <Welcome />

    <div class="bg-dark space-y-32 py-32">
      <Experience />
      <Skills />
      <Projects />
      <Publications />
    </div>
    <Cta />
  </div>
</Layout>
