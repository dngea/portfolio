---
import type { GetStaticPaths } from "astro";
import { getEntry } from "astro:content";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { formatMonthYear } from "@/utils/helper";
import { Badge } from "@/components/ui/badge";
import { Divide } from "lucide-react";
import { render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import MainLayout from "@/layouts/MainLayout.astro";

export const prerender = true;

export const getStaticPaths = (async () => {
  const projects = await getCollection("projects");

  return projects.map((p) => ({ params: { slug: p.id } }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params;

const project = await getEntry("projects", slug);

if (!project) {
  return Astro.redirect("/404");
}

// markdown
const { Content } = await render(project);

console.log("project >>", project);

const { pathname } = Astro.url;
if (!pathname) return Astro.redirect("/404");

const backLink = `/${pathname.split("/").filter(Boolean).slice(0, -1)}`;

export function getYouTubeId(url: string): string | null {
  const patterns = [
    /youtu\.be\/([^?&]+)/,
    /youtube\.com\/watch\?v=([^?&]+)/,
    /youtube\.com\/embed\/([^?&]+)/,
  ];

  for (const pattern of patterns) {
    const match = url.match(pattern);
    if (match) return match[1];
  }

  return null;
}

export function isYouTubeLink(url: string): boolean {
  return url.includes("youtube.com") || url.includes("youtu.be");
}

const youTubeId =
  project.data.videos?.[0] && isYouTubeLink(project.data.videos[0])
    ? getYouTubeId(project.data.videos[0])
    : null;
---

<Layout>
  <MainLayout>
    <div class="mx-auto space-y-12">
      <a
        href={backLink}
        class="hover:text-clay flex w-fit items-center gap-2 font-semibold text-gray-600 transition transition-opacity"
      >
        ← Back to projects
      </a>

      <figure class="mb-12 aspect-video w-full overflow-hidden rounded-2xl">
        <Image
          src={project.data.img}
          alt={project.data.title}
          width={1200}
          height={675}
          class="h-full w-full object-cover"
        />
      </figure>

      <div class="grid grid-cols-[1fr_280px] items-start gap-16">
        <div>
          <time class="text-xs tracking-widest uppercase opacity-50"
            >{formatMonthYear(project.data.date, true)}</time
          >
          <h1 class="mt-2 mb-6 text-4xl font-medium">{project.data.title}</h1>
          <p class="mb-10 leading-relaxed">
            {project.data.description}
          </p>

          <div class="prose prose-neutral max-w-none space-y-6 border-t pt-8">
            <Content />
          </div>
        </div>

        <aside class="space-y-4">
          <div class="space-y-4 rounded-xs border-b p-4">
            <p class="text-sm tracking-wider uppercase">Technologies</p>
            <div class="flex flex-wrap gap-2">
              {project.data.technologies.map((t: string) => <Badge>{t}</Badge>)}
            </div>
          </div>
        </aside>
      </div>

      {
        project.data.videos && (
          <div class="space-y-8 pt-100 pb-50">
            {project.data.videoCaption && (
              <div class="space-y-1.5">
                <h3 class="text-light text-2xl font-semibold">
                  {project.data.videoCaption[0]}
                </h3>
                <p class="text-light text-base italic">
                  {project.data.videoCaption[1]}
                </p>
              </div>
            )}
            <figure class="aspect-video">
              {youTubeId ? (
                <iframe
                  id="project-video"
                  class="h-full w-full"
                  src={`https://www.youtube.com/embed/${youTubeId}`}
                  title={project.data.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                />
              ) : (
                <video
                  class="playsinline w-full object-cover"
                  loop
                  controls
                  id="project-video"
                >
                  {/* <!-- TODO: prefer motion reduce --> */}
                  {project.data.videos.map((video) => {
                    if (video.startsWith("https")) {
                    }
                    const type = video.endsWith(".webm")
                      ? "video/webm"
                      : "video/mp4";

                    return <source src={video} type={type} />;
                  })}
                </video>
              )}
            </figure>
          </div>
        )
      }
    </div>
  </MainLayout>
</Layout>

<script>
  function initFocusVideo() {
    const video = document.getElementById("project-video");
    const overlay = document.getElementById("dark-overlay") as HTMLElement;
    const mainLayout = document.querySelector(".main-layout") as HTMLElement;

    if (video && overlay && mainLayout) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          const rootRect = entry.rootBounds;
          if (!rootRect) return;

          const stripHeight = rootRect.height;
          const videoHeight = entry.boundingClientRect.height;

          const maxPossibleRatio = Math.min(1, stripHeight / videoHeight);

          const focus =
            maxPossibleRatio > 0
              ? Math.min(1, entry.intersectionRatio / maxPossibleRatio)
              : 0;

          const percent = `${(focus * 100).toFixed(1)}%`;

          overlay.style.opacity = focus.toString();
          mainLayout.style.setProperty("--text-focus", percent);
        },
        {
          rootMargin: "-45% 0px -45% 0px",
          threshold: Array.from({ length: 21 }, (_, i) => i / 20),
        },
      );

      observer.observe(video);
    }
  }

  document.addEventListener("astro:page-load", initFocusVideo);
</script>
