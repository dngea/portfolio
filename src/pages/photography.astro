---
import { Badge } from "@/components/ui/badge";
import Layout from "../layouts/Layout.astro";
import MainLayout from "@/layouts/MainLayout.astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import { formatMonthYear } from "@/utils/helper";
import clsx from "clsx";

const photographyProjects: CollectionEntry<"photography">[] =
  await getCollection("photography");

photographyProjects.sort((a, b) => {
  const projectA = a.data.date.getTime();
  const projectB = b.data.date.getTime();

  return projectB - projectA;
});
---

<Layout title="Photography">
  <MainLayout>
    <div class="space-y-4">
      <h1 class="text-4xl font-bold uppercase">Photography</h1>
    </div>

    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        photographyProjects.map((project) => (
          <a href={`/photography/${project.id}`} class="no-underline!">
            <article class="group relative transition duration-200 hover:shadow-sm hover:contrast-105">
              <div
                class={clsx("relative aspect-3/4 overflow-hidden rounded-sm")}
                style="container-type:inline-size;"
              >
                <img
                  src={project.data.img}
                  class={clsx(
                    "absolute h-full w-full object-cover transition duration-250 group-hover:scale-105",
                  )}
                  alt=""
                  loading="lazy"
                />
              </div>

              <div class="absolute bottom-4 left-4 flex flex-col gap-1">
                <Badge
                  variant="secondary"
                  className=" bg-dark! text-light! border-none!  "
                >
                  {formatMonthYear(project.data.date)}
                </Badge>
                <Badge
                  variant="secondary"
                  className=" text-sm! bg-dark! text-light! border-none!  "
                >
                  {project.data.title}
                </Badge>
              </div>
            </article>
          </a>
        ))
      }
    </div>
  </MainLayout>
</Layout>
